<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="15" prefWidth="400" prefHeight="350"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg129078.gui.CreaPersonaggioController"
      style="-fx-padding: 20;">

    <Label text="CREA IL TUO PERSONAGGIO"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Nome:"/>
        <TextField fx:id="txtNome" promptText="Inserisci il tuo nome" prefWidth="250"/>
    </HBox>

    <Label text="Scegli la tua abilita:"
           style="-fx-font-weight: bold;"/>

    <VBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 80 0 80;">
        <RadioButton fx:id="rbPausaCaffe" text="Pausa Caffe"
                     selected="true" onAction="#handleSceltaAbilita"/>
        <RadioButton fx:id="rbPremioProduzione" text="Premio Produzione"
                     onAction="#handleSceltaAbilita"/>
        <RadioButton fx:id="rbLavoroStraordinario" text="Lavoro Straordinario"
                     onAction="#handleSceltaAbilita"/>
    </VBox>

    <Label fx:id="lblDescrizione"
           text="Cura 15 HP. Ideale per chi vuole resistere a lungo."
           wrapText="true" prefWidth="350"
           style="-fx-font-style: italic; -fx-text-fill: #555555;"/>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Indietro" prefWidth="120" onAction="#handleIndietro"/>
        <Button text="Inizia!" prefWidth="120" onAction="#handleIniziaPartita"
                style="-fx-font-weight: bold;"/>
    </HBox>

</VBox>